{
  "name": "@holostaff/cli",
  "version": "0.1.1",
  "description": "Holostaff CLI — scan, instrument, and embed copilots in your codebase",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Holostaff-AI/holostaff-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Holostaff-AI/holostaff-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Holostaff-AI/holostaff-cli/issues"
  },
  "keywords": [
    "holostaff",
    "cli",
    "ai-agent",
    "knowledge-base",
    "copilot",
    "instrumentation"
  ],
  "type": "module",
  "bin": {
    "holostaff": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "spike:azure": "tsx src/spike/azureSpike.ts",
    "spike:tools": "tsx src/spike/toolsSmoke.ts",
    "spike:scan": "tsx src/spike/scanSmoke.ts",
    "spike:scan-ink": "tsx src/spike/scanInkSmoke.tsx",
    "spike:trust-report": "tsx src/spike/trustReportSnapshot.tsx",
    "spike:upload": "tsx src/spike/uploadSmoke.ts",
    "spike:chat": "tsx src/spike/chatSmoke.ts",
    "spike:refine": "tsx src/spike/refineSmoke.ts",
    "spike:add-repo": "tsx src/spike/addRepoSmoke.ts",
    "spike:instrument": "tsx src/spike/instrumentSmoke.ts",
    "spike:embed": "tsx src/spike/embedSmoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.131",
    "@anthropic-ai/sdk": "^0.95.0",
    "ink": "^5.2.1",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
